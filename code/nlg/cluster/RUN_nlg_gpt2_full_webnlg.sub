#!/bin/bash
#SBATCH --job-name=nlg_gpt2_webnlg_full
#SBATCH --partition=default_partition
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=4
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH --requeue
#SBATCH --output=logs/NLG_GPT2_WebNLG_full-%j.out
#SBATCH --error=logs/NLG_GPT2_WebNLG_full-%j.err

set -uo pipefail

cd "${SLURM_SUBMIT_DIR}" || exit 1
source /share/apps/software/anaconda3/etc/profile.d/conda.sh || exit 1
conda activate "${CONDA_ENV:-arc-sft-qwen35}" || exit 1

export KMP_DUPLICATE_LIB_OK=TRUE
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
export MODEL_NAME="${MODEL_NAME:-gpt2-medium}"

GPU_NAME="$(nvidia-smi --query-gpu=name --format=csv,noheader | head -1 || true)"
GPU_CAP="$(nvidia-smi --query-gpu=compute_cap --format=csv,noheader | head -1 | tr -d ' ' || true)"
if [ "$GPU_CAP" != "8.6" ]; then
  echo "Need an A6000/Ampere sm_86 GPU for this run; got ${GPU_NAME} (compute capability ${GPU_CAP}). Requeueing." >&2
  scontrol requeue "$SLURM_JOB_ID"
  exit 0
fi

mkdir -p logs nlg/results/paper_gpt2_full/webnlg || exit 1
python -m pip install -r reimpl/requirements.txt --user || exit 1

bash nlg/run_nlg_gpt2_full_ft_matrix.sh webnlg || exit 1
