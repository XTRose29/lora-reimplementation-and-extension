#!/bin/bash
#SBATCH --job-name=nlg_e2e_full
#SBATCH --partition=default_partition
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=4
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH --requeue
#SBATCH --output=logs/NLG_E2E_full-%j.out
#SBATCH --error=logs/NLG_E2E_full-%j.err

set -uo pipefail

cd "${SLURM_SUBMIT_DIR}" || exit 1
source /share/apps/software/anaconda3/etc/profile.d/conda.sh || exit 1
conda activate "${CONDA_ENV:-arc-sft-qwen35}" || exit 1

export KMP_DUPLICATE_LIB_OK=TRUE
export TOKENIZERS_PARALLELISM=false
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

GPU_NAME="$(nvidia-smi --query-gpu=name --format=csv,noheader | head -1 || true)"
GPU_CAP="$(nvidia-smi --query-gpu=compute_cap --format=csv,noheader | head -1 | tr -d ' ' || true)"
if echo "$GPU_NAME" | grep -Eiq 'Blackwell|B200' || [ "$GPU_CAP" = "8.9" ]; then
  echo "Unsupported GPU for current PyTorch build: ${GPU_NAME} (compute capability ${GPU_CAP}). Requeueing." >&2
  scontrol requeue "$SLURM_JOB_ID"
  exit 0
fi

mkdir -p logs results/nlg/full/e2e || exit 1
python -m pip install -r code/requirements.txt --user || exit 1

bash code/nlg/run_nlg_full_matrix.sh e2e || exit 1

